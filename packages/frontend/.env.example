# Copy to .env and fill in real values. Vite bakes these into the build at BUILD
# TIME — set them in your build environment before running `npm run build`,
# not just at runtime (unlike backend env vars, changing this after building
# does nothing until you rebuild).

# Backend API base URL. Several places also derive the bare backend origin from
# this by stripping "/api" (e.g. for the uploads static host and the socket.io
# connection), so keep the "/api" suffix here.
VITE_API_URL=http://localhost:3001/api

# --- Optional, feature-specific (each has a working "demo" fallback in dev) ---
VITE_GOOGLE_CLIENT_ID=
VITE_LOTTIEFILES_API_KEY=
VITE_TENOR_API_KEY=
VITE_STORYSET_API_KEY=
VITE_PEXELS_API_KEY=
