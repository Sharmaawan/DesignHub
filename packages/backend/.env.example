# Copy to .env and fill in real values. Never commit the real .env file.

# --- Core (required) ---
DATABASE_URL="mysql://user:password@localhost:3306/canva"
PORT=3001
FRONTEND_URL=http://localhost:5173
# Random 32+ byte secrets — e.g. `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
# In production these MUST be set: the app refuses to start with its dev fallback
# values if NODE_ENV=production and either is missing.
JWT_SECRET=
API_KEY_SECRET=

# --- AI providers (optional system-wide fallback; users can also add their own
# key per-provider in Settings, which takes priority over these) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Google Sign-In (optional) ---
GOOGLE_CLIENT_ID=

# --- Teams ---
# Every user is auto-placed into ONE shared org team on login/registration (the
# maker/approver workflow only governs team members). This names that team.
DEFAULT_TEAM_NAME=Cutm Organization
# Comma-separated emails that get the 'admin' (approver) role in that team; everyone
# else is an 'editor' (maker). Re-synced on every login, so changing this list and
# re-logging in promotes/demotes with no DB edit.
ADMIN_EMAILS=kalyankv@cutmap.ac.in,221801370004@cutmap.ac.in

# --- Outgoing email (team invites, notifications) ---
# Three ways to send, tried in this order: (1) a user's own SMTP connected in
# Settings > Email; (2) a local msmtp relay; (3) system SMTP_* below. If none is
# set, sending is skipped and the invite link is just logged.
#
# Option A — msmtp (reuses the server's ~/.msmtprc for host/auth/TLS):
#   MSMTP_PATH=/usr/bin/msmtp
#   MSMTP_ACCOUNT=default        # optional: which msmtprc account to use (-a)
#   MSMTP_FROM=no-reply@yourdomain.com   # must be an identity msmtprc may send as
#
# Option B — direct SMTP:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=you@gmail.com
#   SMTP_PASS=your-app-password

# --- Social publishing (packages/backend/src/routes/social.ts) ---
# Used to build OAuth redirect_uri values sent to each platform. Defaults to
# http://localhost:3001 if unset.
API_BASE_URL=http://localhost:3001

# Public origin the generated design image is served from. Social platforms fetch
# the media URL from their OWN servers, so this must be publicly reachable — not
# localhost and not a relative path, or publishing fails with an opaque upstream
# error. Falls back to FRONTEND_URL, which is correct whenever the reverse proxy
# serves /uploads on the same origin as the app.
# PUBLIC_MEDIA_URL=https://designhub.example.com

# Facebook + Instagram share one Meta developer app (Instagram Business publishing
# goes through a Facebook Page linked to the Instagram account). Create an app at
# https://developers.facebook.com/apps, add the "Facebook Login" + "Instagram Graph
# API" products, and set these from the app's Basic Settings. Until both are set,
# Facebook/Instagram show as "not configured" in the Publish UI.
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# LinkedIn publishing (OAuth is real; posting/analytics implemented in
# lib/socialPlatforms/linkedin.ts).
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Not implemented yet (lib/socialPlatforms/twitter.ts, pinterest.ts are stubs) —
# setting these alone won't enable posting.
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=
