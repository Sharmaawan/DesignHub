generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(cuid())
  name             String?
  email            String    @unique
  passwordHash     String?   @map("password_hash")
  avatar           String?
  googleId         String?   @unique @map("google_id")
  lastLogin        DateTime? @map("last_login")
  role             String    @default("user")
  subscriptionPlan String?   @default("free") @map("subscription_plan")
  provider         String?
  providerId       String?   @unique @map("provider_id")
  smtpHost         String?   @map("smtp_host")
  smtpPort         Int?      @default(587) @map("smtp_port")
  smtpUser         String?   @map("smtp_user")
  smtpPass         String?   @map("smtp_pass")
  smtpEnabled      Boolean   @default(false) @map("smtp_enabled")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  projects         Project[]
  uploads          Upload[]
  folders          Folder[]
  teamsOwned       Team[]       @relation("TeamOwner")
  teamMemberships  TeamMember[]
  comments         Comment[]
  notifications    Notification[]
  favorites        Favorite[]
  recentActivities RecentActivity[]
  userPreferences  UserPreferences?
  collaboratorOn   Collaborator[]
  projectShares    ProjectShare[]
  brandColors      BrandColor[]
  brandFonts       BrandFont[]
  brandLogos       BrandLogo[]
  brandTemplates   BrandTemplate[]
  brandAssets      UserBrandAsset[]
  aiSettings       AISetting[]
  teamInvitesSent  TeamInvite[]     @relation("TeamInviteSender")
  aiRequests       AIRequest[]
  aiGenerations    AIGeneration[]
  backgroundRemovals BackgroundRemoval[]
  socialAccounts   SocialAccount[]
  socialPosts      SocialPost[]
  uploadedTemplates Template[]

  @@map("users")
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  title       String?
  thumbnail   String?
  canvasData  Json?    @map("canvas_data")
  status      String   @default("draft")
  ownerId     String   @map("owner_id")
  isPublic    Boolean  @default(false) @map("is_public")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  owner          User            @relation(fields: [ownerId], references: [id])
  pages          Page[]
  comments       Comment[]
  versions       Version[]
  shares         ProjectShare[]
  collaborators  Collaborator[]
  shareLinks     ShareLink[]
  exportHistory  ExportHistory[]
  favorites      Favorite[]
  brandTemplates BrandTemplate[]
  socialPosts    SocialPost[]

  @@map("projects")
}

model Page {
  id         String   @id @default(cuid())
  name       String   @default("Page")
  pageNumber Int?     @map("page_number")
  pageData   Json?    @map("page_data")
  projectId  String   @map("project_id")
  index      Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  project  Project   @relation(fields: [projectId], references: [id])
  elements Element[]

  @@map("pages")
}

model Element {
  id        String   @id @default(cuid())
  type      String
  data      Json
  pageId    String   @map("page_id")
  locked    Boolean  @default(false)
  hidden    Boolean  @default(false)
  index     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  page Page @relation(fields: [pageId], references: [id])

  @@map("elements")
}

model Folder {
  id        String   @id @default(cuid())
  name      String
  ownerId   String   @map("owner_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  owner User @relation(fields: [ownerId], references: [id])

  @@map("folders")
}

model Template {
  id          String   @id @default(cuid())
  name        String
  category    String
  subcategory String?
  thumbnail   String
  templateData Json?  @map("template_data")
  data        Json?
  tags        Json
  isPremium   Boolean  @default(false) @map("is_premium")
  // Null for the built-in/seed catalog — those are shared by everyone and never
  // deletable. Only templates a user uploaded themselves (ownerId set) can be
  // deleted/restored, so nobody can remove a template out from under other users.
  ownerId     String?   @map("owner_id")
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  owner     User?      @relation(fields: [ownerId], references: [id])
  favorites Favorite[]

  @@map("templates")
}

model Category {
  id        String @id @default(cuid())
  name      String
  icon      String?
  sortOrder Int    @default(0) @map("sort_order")

  @@map("categories")
}

model Upload {
  id        String   @id @default(cuid())
  fileName  String   @map("file_name")
  fileUrl   String   @map("file_url")
  fileType  String   @map("file_type")
  url       String?
  size      Int?
  ownerId   String   @map("owner_id")
  createdAt DateTime @default(now()) @map("created_at")

  owner User @relation(fields: [ownerId], references: [id])

  @@map("uploads")
}

model Team {
  id        String   @id @default(cuid())
  name      String
  ownerId   String   @map("owner_id")
  createdAt DateTime @default(now()) @map("created_at")

  owner    User          @relation("TeamOwner", fields: [ownerId], references: [id])
  members  TeamMember[]
  brandAssets BrandAsset[]
  invites  TeamInvite[]

  @@map("teams")
}

model TeamMember {
  id       String   @id @default(cuid())
  teamId   String   @map("team_id")
  userId   String   @map("user_id")
  role     String   @default("member")
  joinedAt DateTime @default(now()) @map("joined_at")

  team Team @relation(fields: [teamId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([teamId, userId])
  @@map("team_members")
}

model Collaborator {
  id          String   @id @default(cuid())
  projectId   String   @map("project_id")
  userId      String   @map("user_id")
  permission  String   @default("view")
  invitedBy   String?  @map("invited_by")
  createdAt   DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@unique([projectId, userId])
  @@map("collaborators")
}

model ShareLink {
  id          String    @id @default(cuid())
  projectId   String    @map("project_id")
  token       String    @unique
  accessLevel String    @default("view") @map("access_level")
  expiresAt   DateTime? @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id])

  @@map("share_links")
}

model Comment {
  id          String   @id @default(cuid())
  content     String   @map("comment_text")
  projectId   String?  @map("project_id")
  userId      String   @map("user_id")
  elementId   String?  @map("element_id")
  x           Float?
  y           Float?
  resolved    Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  project Project? @relation(fields: [projectId], references: [id])
  user    User     @relation(fields: [userId], references: [id])

  @@map("comments")
}

model Version {
  id            String   @id @default(cuid())
  projectId     String   @map("project_id")
  versionNumber Int      @default(1) @map("version_number")
  data          Json?
  canvasSnapshot Json?  @map("canvas_snapshot")
  createdById   String?  @map("created_by_id")
  createdAt     DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id])

  @@map("versions")
}

model ProjectShare {
  id         String   @id @default(cuid())
  projectId  String   @map("project_id")
  userId     String   @map("user_id")
  permission String   @default("view")
  createdAt  DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@map("project_shares")
}

model Favorite {
  id         String   @id @default(cuid())
  projectId  String?  @map("project_id")
  templateId String?  @map("template_id")
  userId     String   @map("user_id")
  createdAt  DateTime @default(now()) @map("created_at")

  project  Project?  @relation(fields: [projectId], references: [id])
  template Template? @relation(fields: [templateId], references: [id])
  user     User      @relation(fields: [userId], references: [id])

  @@unique([projectId, userId])
  @@unique([templateId, userId])
  @@map("favorites")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  type      String
  message   String
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("notifications")
}

model BrandAsset {
  id        String   @id @default(cuid())
  teamId    String   @map("team_id")
  assetType String   @map("asset_type")
  assetUrl  String   @map("asset_url")
  createdAt DateTime @default(now()) @map("created_at")

  team Team @relation(fields: [teamId], references: [id])

  @@map("brand_assets")
}

model UserBrandAsset {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  name      String?
  url       String   @db.LongText
  type      String
  folder    String?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("user_brand_assets")
}

model RecentActivity {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  activityType String   @map("activity_type")
  referenceId  String?  @map("reference_id")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("recent_activity")
}

model ExportHistory {
  id         String   @id @default(cuid())
  projectId  String   @map("project_id")
  exportType String   @map("export_type")
  fileUrl    String?  @map("file_url")
  createdAt  DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id])

  @@map("export_history")
}

model UserPreferences {
  id                String   @id @default(cuid())
  userId            String   @unique @map("user_id")
  theme             String   @default("light")
  language          String   @default("en")
  autosaveInterval  Int      @default(30) @map("autosave_interval")
  editorPreferences Json?    @map("editor_preferences")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@map("user_preferences")
}

model BrandColor {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  hex       String
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("brand_colors")
}

model BrandFont {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  name      String
  type      String
  url       String?  @db.LongText
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("brand_fonts")
}

model BrandLogo {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  name      String?
  url       String   @db.LongText
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("brand_logos")
}

model BrandTemplate {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  projectId String   @map("project_id")
  category  String?
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id])
  project Project @relation(fields: [projectId], references: [id])

  @@map("brand_templates")
}

model AISetting {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  provider     String
  encryptedKey String   @map("encrypted_key")
  model        String?
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, provider])
  @@map("ai_settings")
}

model TeamInvite {
  id           String   @id @default(cuid())
  teamId       String   @map("team_id")
  email        String
  role         String   @default("editor")
  invitedById  String   @map("invited_by_id")
  status       String   @default("pending")
  token        String   @unique
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")

  team      Team @relation(fields: [teamId], references: [id])
  invitedBy User @relation("TeamInviteSender", fields: [invitedById], references: [id])

  @@map("team_invites")
}

model ProductUpdate {
  id          String   @id @default(cuid())
  title       String
  description String
  icon        String   @default("🚀")
  badge       String?
  category    String   @default("product_update")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("product_updates")
}

model AIRequest {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  provider     String
  prompt       String   @db.Text
  contentType  String   @map("content_type")
  tokensUsed   Int?     @map("tokens_used")
  status       String   @default("pending")
  error        String?  @db.Text
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("ai_requests")
}

model AIGeneration {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  provider     String
  prompt       String   @db.Text
  result       String   @db.Text
  contentType  String   @map("content_type")
  tokensUsed   Int?     @map("tokens_used")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("ai_generations")
}

model BackgroundRemoval {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  originalUrl   String   @map("original_url")
  resultUrl     String?  @map("result_url")
  status        String   @default("pending")
  error         String?
  createdAt     DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("background_removals")
}

model SocialAccount {
  id               String    @id @default(cuid())
  userId           String    @map("user_id")
  platform         String    // 'facebook' | 'instagram' | 'linkedin' | 'twitter' | 'pinterest'
  platformUserId   String    @map("platform_user_id")
  platformUsername String?   @map("platform_username")
  accessToken      String    @db.LongText @map("access_token")   // encrypted
  refreshToken     String?   @db.LongText @map("refresh_token")  // encrypted
  tokenExpiresAt   DateTime? @map("token_expires_at")
  isActive         Boolean   @default(true) @map("is_active")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  user  User         @relation(fields: [userId], references: [id])
  posts SocialPost[]

  @@unique([userId, platform, platformUserId])
  @@map("social_accounts")
}

model SocialPost {
  id              String    @id @default(cuid())
  userId          String    @map("user_id")
  projectId       String?   @map("project_id")
  socialAccountId String    @map("social_account_id")
  platform        String
  status          String    @default("draft") // draft|pending_approval|rejected|scheduled|publishing|published|failed
  mediaType       String    @map("media_type") // image|video|carousel|story
  mediaUrls       Json      @map("media_urls")
  caption         String?   @db.Text
  hashtags        Json?
  altText         String?   @map("alt_text") @db.Text
  firstComment    String?   @map("first_comment") @db.Text
  linkUrl         String?   @map("link_url")
  scheduledFor    DateTime? @map("scheduled_for")
  publishedAt     DateTime? @map("published_at")
  platformPostId  String?   @map("platform_post_id")
  errorMessage    String?   @map("error_message") @db.Text
  // Maker/approver workflow. When a team member with the 'maker' role submits a
  // post, it is held at status 'pending_approval' scoped to teamId; an 'approver'
  // on that team then approves (→ published/scheduled) or rejects it. Null teamId
  // means the author could publish directly (no maker role), the pre-existing path.
  teamId          String?   @map("team_id")
  submittedById   String?   @map("submitted_by_id")
  approvedById    String?   @map("approved_by_id")
  approvedAt      DateTime? @map("approved_at")
  rejectionReason String?   @map("rejection_reason") @db.Text
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  user          User                 @relation(fields: [userId], references: [id])
  project       Project?             @relation(fields: [projectId], references: [id])
  socialAccount SocialAccount        @relation(fields: [socialAccountId], references: [id])
  analytics     SocialPostAnalytics?

  @@index([status, scheduledFor])
  @@index([userId])
  @@index([teamId, status])
  @@map("social_posts")
}

model SocialPostAnalytics {
  id           String   @id @default(cuid())
  socialPostId String   @unique @map("social_post_id")
  likes        Int      @default(0)
  comments     Int      @default(0)
  shares       Int      @default(0)
  reach        Int      @default(0)
  impressions  Int      @default(0)
  fetchedAt    DateTime @default(now()) @map("fetched_at")

  socialPost SocialPost @relation(fields: [socialPostId], references: [id])

  @@map("social_post_analytics")
}
